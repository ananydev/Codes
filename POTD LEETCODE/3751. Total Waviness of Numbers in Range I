class Solution {
    public int totalWaviness(int num1, int num2) 
    {
        int totcnt = 0;
        int k = 0;

        // int arr[] = new int[num2 - num1 + 1];
        // for(int i = num1; i <= num2; i++)
        // {
        //     arr[k++] = i;
        // }

        // int n = arr.length;

        for(int i = num1; i <= num2; i++)
        {
            int cnt = 0;  
            String elem = String.valueOf(i);
 
            for(int j = 1; j < elem.length() - 1; j++)
            {
                char prevch = elem.charAt(j - 1);
                char ch = elem.charAt(j);
                char nextch = elem.charAt(j + 1);

                if((prevch < ch && ch > nextch) ||
                   (prevch > ch && ch < nextch))
                {
                    cnt++;
                }
            }
            totcnt += cnt;
        }

        return totcnt;
    }
}
